{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hwkport",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-26",
  "assets": {
    "directory": "./dashboard",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
